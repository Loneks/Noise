            ],
            "2010": [
                { image: "/images/ranking/rank-1.png", name: "To Pimp a Butterfly", type: "Album", artist: "Kendrick Lamar", year: "2015" },
                { image: "/images/ranking/rank-2.png", name: "Blonde", type: "Album", artist: "Frank Ocean", year: "2016" },
                { image: "/images/ranking/rank-3.png", name: "Lemonade", type: "Album", artist: "Beyoncé", year: "2016" },
                { image: "/images/ranking/rank-4.png", name: "Random Access Memories", type: "Album", artist: "Daft Punk", year: "2013" },
                { image: "/images/ranking/rank-5.png", name: "Rolling in the Deep", type: "Track", artist: "Adele", year: "2010" },
                { image: "/images/ranking/rank-1.png", name: "Alright", type: "Track", artist: "Kendrick Lamar", year: "2015" },
                { image: "/images/ranking/rank-2.png", name: "Get Lucky", type: "Track", artist: "Daft Punk", year: "2013" },
                { image: "/images/ranking/rank-3.png", name: "Bad Guy", type: "Track", artist: "Billie Eilish", year: "2019" },
                { image: "/images/ranking/rank-4.png", name: "Channel Orange", type: "Album", artist: "Frank Ocean", year: "2012" },
                { image: "/images/ranking/rank-5.png", name: "21", type: "Album", artist: "Adele", year: "2011" }
            ],
            "Now": [
                { image: "/images/ranking/rank-1.png", name: "Modern Sound", type: "Album", artist: "Various Artists", year: "2024" },
                { image: "/images/ranking/rank-2.png", name: "Digital Culture", type: "Album", artist: "Various Artists", year: "2024" },
                { image: "/images/ranking/rank-3.png", name: "AI Music Era", type: "Track", artist: "Digital Artists", year: "2025" },
                { image: "/images/ranking/rank-4.png", name: "Global Pop", type: "Album", artist: "Various Artists", year: "2025" },
                { image: "/images/ranking/rank-5.png", name: "Online Sound", type: "Track", artist: "Various Artists", year: "2026" },
                { image: "/images/ranking/rank-1.png", name: "Streaming Generation", type: "Album", artist: "Various Artists", year: "2024" },
                { image: "/images/ranking/rank-2.png", name: "Virtual Concerts", type: "Track", artist: "Digital Artists", year: "2025" },
                { image: "/images/ranking/rank-3.png", name: "Social Media Hits", type: "Album", artist: "Various Artists", year: "2025" },
                { image: "/images/ranking/rank-4.png", name: "New Wave Online", type: "Track", artist: "Various Artists", year: "2026" },
                { image: "/images/ranking/rank-5.png", name: "Future Music", type: "Album", artist: "Various Artists", year: "2026" }
            ]
        };

        const buttons = document.querySelectorAll(".timeline-year");
        const title = document.getElementById("timeline-title");
        const subtitle = document.getElementById("timeline-subtitle");
        const content = document.getElementById("timeline-content");
        const card1 = document.getElementById("timeline-card-1");
        const card2 = document.getElementById("timeline-card-2");
        const card3 = document.getElementById("timeline-card-3");

        const rowsPerPage = 5;
        let currentRankingPage = 0;
        let currentRankingYear = "1900";

        const topRow = document.getElementById("ranking-top-row");
        const tableBody = document.getElementById("ranking-table-body");
        const dotsContainer = document.getElementById("ranking-dots");
        const prevButton = document.getElementById("ranking-prev");
        const nextButton = document.getElementById("ranking-next");

        function renderTopRanking(year) {
            const items = rankingData[year].slice(0, 5);

            topRow.innerHTML = items.map((item, index) => `
                <article class="ranking-card">
                    <img src="${item.image}" alt="${item.name} cover" class="ranking-cover" />
                    <h3>${item.name}</h3>
                    <p>${item.artist}</p>
                    <img src="/images/ranking/places/rank-number-${index + 1}.png" alt="Rank ${index + 1}" class="ranking-place-full" />
                </article>
            `).join("");
        }

        function renderRankingTable() {
            const items = rankingData[currentRankingYear].slice(5);
            const start = currentRankingPage * rowsPerPage;
            const end = start + rowsPerPage;
            const pageItems = items.slice(start, end);

            tableBody.innerHTML = pageItems.map((item, index) => `
                <div class="ranking-table-row">
                    <span>${start + index + 6}</span>
                    <img src="${item.image}" alt="${item.name} cover" />
                    <span>${item.name}</span>
                    <span>${item.type}</span>
                    <span>${item.artist}</span>
                    <span>${item.year}</span>
                </div>
            `).join("");

            renderRankingDots();
        }

        function renderRankingDots() {
            const items = rankingData[currentRankingYear].slice(5);
            const totalPages = Math.ceil(items.length / rowsPerPage);

            dotsContainer.innerHTML = "";

            for (let i = 0; i < totalPages; i++) {
                const dot = document.createElement("span");

                if (i === currentRankingPage) {
                    dot.classList.add("active-dot");
                }

                dot.addEventListener("click", () => {
                    currentRankingPage = i;
                    renderRankingTable();
                });

                dotsContainer.appendChild(dot);
            }
        }

        function renderRankingForYear(year) {
            currentRankingYear = year;
            currentRankingPage = 0;

            renderTopRanking(year);
            renderRankingTable();
        }

        prevButton.addEventListener("click", () => {
            const items = rankingData[currentRankingYear].slice(5);
            const totalPages = Math.ceil(items.length / rowsPerPage);

            currentRankingPage--;

            if (currentRankingPage < 0) {
                currentRankingPage = totalPages - 1;
            }

            renderRankingTable();
        });

        nextButton.addEventListener("click", () => {
            const items = rankingData[currentRankingYear].slice(5);
            const totalPages = Math.ceil(items.length / rowsPerPage);

            currentRankingPage++;

            if (currentRankingPage >= totalPages) {
                currentRankingPage = 0;
            }

            renderRankingTable();
        });

        buttons.forEach(button => {
            button.addEventListener("click", () => {
                const year = button.dataset.year;
                const data = timelineData[year];

                buttons.forEach(btn => btn.classList.remove("active-year"));
                button.classList.add("active-year");

                content.classList.remove("timeline-animate");
                void content.offsetWidth;
                content.classList.add("timeline-animate");

                title.textContent = data.title;
                subtitle.textContent = data.subtitle;

                card1.querySelector("span").textContent = data.cards[0];
                card2.querySelector("span").textContent = data.cards[1];
                card3.querySelector("span").textContent = data.cards[2];

                const images = timelineImages[year];

                card1.style.backgroundImage = `url('${images[0]}')`;
                card2.style.backgroundImage = `url('${images[1]}')`;
                card3.style.backgroundImage = `url('${images[2]}')`;

                content.innerHTML = data.text;

                renderRankingForYear(year);
            });
        });

        renderRankingForYear("1900");
    </script>
}