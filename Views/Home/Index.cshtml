@{
    ViewData["Title"] = "Museum";
    ViewData["SectionName"] = "History";
}

<section class="museum-page">
    <div class="timeline" id="timeline">
        <button class="timeline-year active-year" data-year="1900">1900</button>
        <button class="timeline-year" data-year="1910">1910</button>
        <button class="timeline-year" data-year="1920">1920</button>
        <button class="timeline-year" data-year="1930">1930</button>
        <button class="timeline-year" data-year="1940">1940</button>
        <button class="timeline-year" data-year="1950">1950</button>
        <button class="timeline-year" data-year="1960">1960</button>
        <button class="timeline-year" data-year="1970">1970</button>
        <button class="timeline-year" data-year="1980">1980</button>
        <button class="timeline-year" data-year="1990">1990</button>
        <button class="timeline-year" data-year="2000">2000</button>
        <button class="timeline-year" data-year="2010">2010</button>
        <button class="timeline-year" data-year="Now">Now</button>
    </div>

    <section class="history-layout">
        <div class="history-images">
            <p class="eyebrow">Overview</p>
            <h1 id="timeline-title">All music history</h1>
            <h2 id="timeline-subtitle">Until the 20th century</h2>

            <div class="history-photo image-card" id="timeline-card-1"
                 style="background-image: url('/images/history/jazz-age.jpg');">
                <span>Jazz Age</span>
            </div>

            <div class="history-photo image-card" id="timeline-card-2"
                 style="background-image: url('/images/history/classical-era.jpg');">
                <span>Classical Era</span>
            </div>

            <div class="history-photo image-card" id="timeline-card-3"
                 style="background-image: url('/images/history/modern-sound.jpg');">
                <span>Modern Sound</span>
            </div>
        </div>

        <div class="history-text timeline-content" id="timeline-content">
            <p>
                Music has always been closely connected with culture, society and everyday life.
                It developed from simple ritual sounds into complex artistic forms that shaped
                human communication, emotions and identity.
            </p>

            <p>
                In ancient civilizations, music was used during ceremonies, celebrations and
                religious practices. Over time, musical instruments, rhythm and notation became
                more organized.
            </p>

            <p>
                During the Middle Ages and Renaissance, music became an important part of
                education, church culture and public life. Later, composers began to experiment
                with harmony, structure and emotional expression.
            </p>

            <p>
                In the 20th century, music changed rapidly because of recording technologies,
                radio, television and the internet. Jazz, rock, pop, hip-hop and electronic music
                became global cultural forces.
            </p>

            <p>
                Noise Museum presents music history through genres, artists, albums, multimedia
                materials and news updates.
            </p>
        </div>
    </section>

    <section class="ranking-preview ranking-museum">
        <p class="eyebrow text-center">Ranking</p>
        <h2>Top 5 Most Influential Albums and Tracks of the Decade</h2>

        <div class="ranking-row" id="ranking-top-row"></div>

        <section class="ranking-table-section">
            <h2>TOP 50 TRACK AND ALBUMS</h2>

            <div class="ranking-table">
                <div class="ranking-table-head">
                    <span>#</span>
                    <span></span>
                    <span>Name</span>
                    <span>Type</span>
                    <span>Artist</span>
                    <span>Year</span>
                </div>

                <div id="ranking-table-body"></div>
            </div>

            <div class="ranking-pagination">
                <button type="button" id="ranking-prev">‹</button>

                <div id="ranking-dots" class="ranking-dots"></div>

                <button type="button" id="ranking-next">›</button>
            </div>
        </section>

        <div class="home-actions">
            <a class="card-link" asp-controller="Albums" asp-action="Index">Перейти до альбомів</a>
            <a class="card-link" asp-controller="Genres" asp-action="Index">Перейти до жанрів</a>
        </div>
    </section>
</section>

