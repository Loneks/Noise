@model Noise.Models.MediaItem

@{
    ViewData["Title"] = "Редагувати інформаційний матеріал";
}

<section class="page-hero">
    <p class="eyebrow">Admin Panel</p>
    <h1>Редагувати інформаційний матеріал</h1>
    <p>
        Форма для зміни інформації про зображення, обкладинку, постер, ілюстрацію або зовнішнє посилання.
    </p>
</section>

<section class="details-layout">
    <div class="details-main">
        <form asp-action="EditMediaItem" method="post" class="admin-form">
            <input type="hidden" asp-for="Id" />

            <div class="form-group">
                <label asp-for="Title">Назва матеріалу</label>
                <input asp-for="Title" class="form-control" />
            </div>

            <div class="form-group">
                <label asp-for="Type">Тип матеріалу</label>
                <input asp-for="Type" class="form-control" />
            </div>

            <div class="form-group">
                <label asp-for="UrlOrPath">Шлях або зовнішнє посилання</label>
                <input asp-for="UrlOrPath" class="form-control" />
            </div>

            <div class="form-group">
                <label asp-for="Description">Опис матеріалу</label>
                <textarea asp-for="Description" class="form-control" rows="6"></textarea>
            </div>

            <div class="form-group">
                <label asp-for="MusicItemId">Пов’язаний альбом або музичний матеріал</label>
                <select asp-for="MusicItemId" class="form-control">
                    @foreach (var musicItem in ViewBag.MusicItems)
                    {
                        <option value="@musicItem.Id">
                            @musicItem.Title — @musicItem.Artist?.Name
                        </option>
                    }
                </select>
            </div>

            <button type="submit" class="admin-button">
                Зберегти зміни
            </button>

            <a class="card-link ms-3" asp-controller="Admin" asp-action="MediaItems">
                Назад до керування матеріалами
            </a>
        </form>
    </div>
</section>