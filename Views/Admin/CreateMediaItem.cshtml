@model Noise.Models.MediaItem

@{
    ViewData["Title"] = "Додати інформаційний матеріал";
}

<section class="page-hero">
    <p class="eyebrow">Admin Panel</p>
    <h1>Додати інформаційний матеріал</h1>
    <p>
        Форма для додавання зображення, обкладинки, постера, ілюстрації або зовнішнього посилання.
        Матеріали використовуються як інформаційний та візуальний супровід, без прослуховування музики.
    </p>
</section>

<section class="details-layout">
    <div class="details-main">
        <form asp-action="CreateMediaItem" method="post" class="admin-form">
            <div class="form-group">
                <label asp-for="Title">Назва матеріалу</label>
                <input asp-for="Title" class="form-control" placeholder="Наприклад: Abbey Road Cover" />
            </div>

            <div class="form-group">
                <label asp-for="Type">Тип матеріалу</label>
                <input asp-for="Type" class="form-control" placeholder="Наприклад: image, poster, cover, link" />
            </div>

            <div class="form-group">
                <label asp-for="UrlOrPath">Шлях або зовнішнє посилання</label>
                <input asp-for="UrlOrPath" class="form-control" placeholder="/images/media/example.jpg або зовнішнє посилання" />
            </div>

            <div class="form-group">
                <label asp-for="Description">Опис матеріалу</label>
                <textarea asp-for="Description" class="form-control" rows="6" placeholder="Введіть опис інформаційного матеріалу"></textarea>
            </div>

            <div class="form-group">
                <label asp-for="MusicItemId">Пов’язаний альбом або музичний матеріал</label>
                <select asp-for="MusicItemId" class="form-control">
                    @foreach (var musicItem in ViewBag.MusicItems)
                    {
                        <option value="@musicItem.Id">
                            @musicItem.Title — @musicItem.Artist?.Name
                        </option>
                    }
                </select>
            </div>

            <button type="submit" class="admin-button">
                Додати матеріал
            </button>

            <a class="card-link ms-3" asp-controller="Admin" asp-action="MediaItems">
                Назад до керування матеріалами
            </a>
        </form>
    </div>
</section>