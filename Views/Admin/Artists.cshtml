@model IEnumerable<Noise.Models.Artist>

@{
    ViewData["Title"] = "Керування виконавцями";
}

<section class="page-hero">
    <p class="eyebrow">Admin Panel</p>
    <h1>Керування виконавцями</h1>
    <p>
        На цій сторінці адміністратор може переглядати, додавати, редагувати та видаляти виконавців і гурти.
    </p>

    <div class="admin-actions">
        <a class="admin-button" asp-controller="Admin" asp-action="CreateArtist">
            Додати виконавця
        </a>

        <a class="admin-button secondary-button" asp-controller="Admin" asp-action="Index">
            Назад до адмін-панелі
        </a>
    </div>
</section>

<section class="content-grid">
    @foreach (var item in Model)
    {
        <article class="content-card">
            <p class="card-meta">
                @item.StartYear
                @if (item.EndYear != null)
                {
                    <span> — @item.EndYear</span>
                }
                else
                {
                    <span> — дотепер</span>
                }
            </p>

            <h2>@item.Name</h2>

            <p>
                Жанр: @item.Genre?.Name<br />
                Країна: @item.Country?.Name
            </p>

            <p>@item.Biography</p>

            <div class="admin-card-actions">
                <div class="admin-card-main-actions">
                    <a class="card-link" asp-controller="Artists" asp-action="Details" asp-route-id="@item.Id">
                        Переглянути
                    </a>

                    <a class="card-link" asp-controller="Admin" asp-action="EditArtist" asp-route-id="@item.Id">
                        Редагувати
                    </a>
                </div>

                <form asp-controller="Admin" asp-action="DeleteArtist" asp-route-id="@item.Id" method="post" class="delete-form">
                    <button type="submit" class="delete-button" onclick="return confirm('Ви точно хочете видалити цього виконавця?');">
                        Видалити
                    </button>
                </form>
            </div>
        </article>
    }
</section>